# Copy to .env and fill only what your workflow needs.
# Never commit .env with real values.

# Hugging Face access for gated/private models or hf:// dataset remotes.
HF_TOKEN=

# Optional token pool for hf://datasets/__namespace__/... remote paths.
# Example:
# HF_TOKEN_POOL_JSON=[{"namespace":"your-org","token":"hf_..."}]
HF_TOKEN_POOL_JSON=
HF_TOKEN_POOL_NAMESPACE=

# Optional Weights & Biases online logging.
WANDB_API_KEY=
WANDB_ENTITY=

# Optional API-backed judge/solver/verifier modes.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional Cloudflare R2 / S3-compatible storage for s3:// or r2:// paths.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# Optional launcher data source. Leave unset when .cache/data/preprocessed
# already exists locally.
# Example: PREPROCESSED_DATA_RCLONE_URI=r2:my-bucket/.cache/data/preprocessed
PREPROCESSED_DATA_RCLONE_URI=
